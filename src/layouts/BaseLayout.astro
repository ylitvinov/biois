---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-top">
        <div class="container header-top-inner">
          <a href="/" class="logo">
            <img src="https://static.tildacdn.com/tild6330-3566-4233-b030-393634306335/Group_3.svg" alt="BIOIS" class="logo-img" />
          </a>

          <div class="header-right">
            <div class="header-socials">
              <a href="https://api.whatsapp.com/send?phone=79892155147" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="social-link">
